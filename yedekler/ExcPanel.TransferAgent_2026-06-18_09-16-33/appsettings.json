{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TransferAgent": {
    "AgentName": "ExcPanel Transfer Agent",
    "AgentId": "transfer-agent-001",
    "PublicHostName": "transfer-agent.local",
    "StorageRootPath": "/var/excpanel/storage",
    "SambaShareName": "excpanel-pst",
    "SftpPort": 22,
    "EnableSftp": false,
    "EnableSamba": false,
    "StorageOwnerUser": "agentdev",
    "StorageOwnerGroup": "agentdev",
    "StorageDirectoryMode": "750",
    "UseSudoForPrivilegedCommands": false
  }
}
