{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TransferAgent": {
    "AgentName": "ExcPanel Transfer Agent",
    "AgentId": "transfer-agent-001",
    "PublicHostName": "transfer-agent.local",
    "StorageRootPath": "/data/excpanel-transfer",
    "SambaShareName": "PSTTransfer$",
    "SftpPort": 22,
    "EnableSftp": true,
    "EnableSamba": true,
    "StorageOwnerUser": "excpanel-agent",
    "StorageOwnerGroup": "excpanel-agent",
    "StorageDirectoryMode": "750",
    "UseSudoForPrivilegedCommands": false
  },
  "Setup": {
    "Mode": "Standalone",
    "StorageRootPath": "/data/excpanel-transfer",
    "DefaultMountPath": "/data/excpanel-transfer",
    "DefaultShareName": "PSTTransfer$",
    "DefaultSftpChrootRoot": "/var/lib/excpanel-sftp/chroots",
    "RequireDomainJoinForSamba": true,
    "RequireSambaForExchangeExport": true,
    "RequireSftpForUserDownload": true,
    "AllowHttpInDevelopment": true
  },
  "AgentSecurity": {
    "Mode": "Standalone",
    "RequireRegistration": false,
    "RequireAgentAuth": false
  },
  "Samba": {
    "Enabled": true,
    "ShareName": "PSTTransfer$",
    "ServerName": "",
    "StorageRoot": "/data/excpanel-transfer",
    "ConfigFilePath": "/etc/samba/excpanel-transfer.conf",
    "MainConfigPath": "/etc/samba/smb.conf",
    "RequiredAdGroup": "DOGRUMAIL-DEMO\\Exchange Trusted Subsystem",
    "RequireDomainJoined": true,
    "AllowGuest": false,
    "SmbMinProtocol": "SMB2",
    "SmbMaxProtocol": "SMB3"
  }
}
